{
  "expo": {
    "name": "낱말 카드",
    "slug": "word-card",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wordcard",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wordcard.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "부모님의 목소리로 낱말 발음을 녹음하기 위해 마이크 접근이 필요해요."
      }
    },
    "android": {
      "package": "com.wordcard.app",
      "adaptiveIcon": {
        "backgroundColor": "#FFF9F4",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["RECORD_AUDIO"]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "name": "낱말 카드",
      "shortName": "낱말카드",
      "themeColor": "#FFB4A2",
      "backgroundColor": "#FFF9F4",
      "display": "standalone",
      "orientation": "portrait",
      "lang": "ko-KR",
      "description": "9개월 아기를 위한 낱말 카드 앱"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFF9F4"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
